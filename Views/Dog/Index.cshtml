@model app_to_do_mysql.Models.DogViewModel

@{
    ViewData["Title"] = "Perrito del día";
}

<link rel="stylesheet" href="~/css/dog.css" />

<div class="dog-container">
    <div class="dog-card">
        <h1 style="color: #9b59b6;">Perrito del día</h1>
        <p>Imagen  desde un servicio WCF .</p>

        @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
        {
            <img src="@Model.ImagenUrl" alt="Perrito del día" class="dog-image" />
        }
        else
        {
            <div class="dog-error">@Model.Mensaje</div>
        }

        <form asp-controller="Dog" asp-action="Index" method="get">
            <button type="submit">Ver otro perrito</button>
        </form>

        <a asp-controller="Account" asp-action="Welcome">Regresar</a>
    </div>
</div>